# Root example env. Copy to .env and fill in real values.
# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend (see backend/.env.example for the full list)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/courseforge
JWT_SECRET=change-me-to-a-very-long-random-secret-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
UPLOAD_DIR=app/uploads
MAX_UPLOAD_MB=100
CORS_ORIGINS=http://localhost:3000
